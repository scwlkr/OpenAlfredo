# Database
# OpenAlfredo defaults to `oax-web/data/oax.db`.
# Leave DATABASE_URL unset unless you intentionally want a different database.
# Use an absolute SQLite URL when overriding, e.g.:
# DATABASE_URL="file:/absolute/path/to/oax.db"

# Telegram bot — leave empty to disable the bot.
# Get a token from @BotFather on Telegram. See README for setup.
TELEGRAM_TOKEN=

# RESTLESS heartbeat cadence (any node-cron expression).
# Default is hourly on the hour. Examples:
#   */15 * * * *   every 15 minutes
#   0 */2 * * *    every 2 hours
#   0 9,18 * * *   at 09:00 and 18:00 daily
HEARTBEAT_CRON="0 * * * *"
HEARTBEAT_ACTIVE=true

# AMBITION task-check cadence (deterministic reminder scan).
AMBITION_CRON="*/30 * * * *"

# AMBITION reflection cadence (LLM-generated morning brief).
# Default is daily at 7am. Set REFLECTION_ACTIVE=false to disable.
REFLECTION_CRON="0 7 * * *"
REFLECTION_ACTIVE=true

# Continuity loop cadence (Golden Goose — adaptive theme-based follow-ups).
# Default is twice daily at 10am and 4pm. Set CONTINUITY_ACTIVE=false to disable.
CONTINUITY_CRON="0 10,16 * * *"
CONTINUITY_ACTIVE=true

# Default Ollama model (used by web chat, telegram chat, and heartbeat when
# no per-chat override is set). Telegram users can switch with /model.
OAX_MODEL="llama3"
